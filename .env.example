# ONX Platform — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to Git — it is in .gitignore

# Database
DATABASE_URL=postgres://username:password@host:port/database?sslmode=disable
POSTGRES_USER=onx_app
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=onx_production

# Authentication
BETTER_AUTH_SECRET=your-32-char-minimum-secret-here
BETTER_AUTH_URL=http://localhost:3000

# Founder Account (created on first bootstrap)
ONX_FOUNDER_EMAIL=founder@yourdomain.com
ONX_FOUNDER_PASSWORD=your-secure-founder-password
ONX_FOUNDER_NAME=ONX Founder

# Optional: Override default port
# PORT=3000

# Optional: Node environment
# NODE_ENV=production
